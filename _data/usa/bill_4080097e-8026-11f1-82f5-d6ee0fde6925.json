{"legislative_session": "119", "identifier": "HR 7903", "title": "Justice for Hind Rajab Act", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [], "other_titles": [{"note": "", "title": "To call for accountability for the killing of innocent civilians, including 5-year-old Hind Rajab and 2 paramedics, in an attack in Gaza City on January 29, 2024, by Israel Defense Forces, to require the Secretary of State to report to Congress on the attack and to determine if any of the weapons and munitions used in the attack were provided by the United States or if any of the soldiers responsible for such killings were United States citizens or were trained by the United States, and for other purposes."}], "other_identifiers": [{"identifier": "ocd-bill-us-119-hr7903"}], "actions": [{"description": "Referred to the Committee on Foreign Affairs, and in addition to the Committee on the Judiciary, for a period to be subsequently determined by the Speaker, in each case for consideration of such provisions as fall within the jurisdiction of the committee concerned.", "date": "2026-03-12T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Introduced in House", "date": "2026-03-12T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "Joaquin Castro", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Joaquin Castro\"}", "organization_id": null}, {"name": "Pramila Jayapal", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Pramila Jayapal\"}", "organization_id": null}, {"name": "Derek Tran", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Derek Tran\"}", "organiz