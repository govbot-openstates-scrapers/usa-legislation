{"legislative_session": "119", "identifier": "HR 7027", "title": "Restore Veterans\u2019 Compensation Act of 2026", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [], "other_titles": [{"note": "", "title": "To amend title 10, United States Code, to eliminate the recoupment of separation pay, special separation benefits, and voluntary separation incentive payments from members of the Armed Forces who subsequently receive disability compensation under laws administered by the Department of Veterans Affairs and to impose limitations on the authority of the Secretary of Defense to recoup such pay from members who subsequently receive military retired or retainer pay."}], "other_identifiers": [{"identifier": "ocd-bill-us-119-hr7027"}], "actions": [{"description": "Referred to the Subcommittee on Disability Assistance and Memorial Affairs.", "date": "2026-05-07T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Referred to the Committee on Armed Services, and in addition to the Committee on Veterans' Affairs, for a period to be subsequently determined by the Speaker, in each case for consideration of such provisions as fall within the jurisdiction of the committee concerned.", "date": "2026-01-13T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Introduced in House", "date": "2026-01-13T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "Mike Levin", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Mike Levin\"}", "organization_id": null}, {"name": "Gus M. Bilirakis", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\