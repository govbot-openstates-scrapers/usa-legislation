{"legislative_session": "119", "identifier": "HR 8126", "title": "Congressional Accountability Act Enhancement Act", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [], "other_titles": [{"note": "", "title": "To amend the Congressional Accountability Act of 1995 to require Members of Congress to reimburse the Treasury for amounts paid as settlements and awards under such Act in all cases of employment discrimination acts committed personally by Members, to permit individuals who file claims under such Act to file an amended claim if the preliminary review of the individual's claim by a hearing officer includes the determination that the individual filing the claim is not a covered employee under such Act or has not stated a claim for which relief may be granted under title IV of such Act, and for other purposes."}], "other_identifiers": [{"identifier": "ocd-bill-us-119-hr8126"}], "actions": [{"description": "Referred to the House Committee on House Administration.", "date": "2026-03-26T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Introduced in House", "date": "2026-03-26T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "Lauren Underwood", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Lauren Underwood\"}", "organization_id": null}, {"name": "Eleanor Holmes Norton", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Eleanor Holmes Norton\"}", "organization_id": null}, {"name": "Sarah McBride", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Sarah McBride\"}", "organization_id": null}, {"name": "Lateefah Simon", "classification":