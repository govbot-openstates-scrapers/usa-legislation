{"legislative_session": "119", "identifier": "HRES 1249", "title": "Unhoused Persons Bill of Rights", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["resolution"], "subject": [], "abstracts": [], "other_titles": [{"note": "", "title": "Expressing that the United States is obligated to permanently end the unhoused crisis by 2029 and uphold, protect, and enforce the civil and human rights of unhoused individuals, including the human rights to housing, universal health care, livable wages, education, employment opportunities, access to public facilities, free movement in public spaces, privacy, confidentiality, internet access, vote, freedom from harassment by law enforcement, private businesses, property owners, and housed residents, and equal rights to health care, legal representation, and social services without discrimination based on housing status."}], "other_identifiers": [{"identifier": "ocd-bill-us-119-hres1249"}], "actions": [{"description": "Referred to the Committee on Financial Services, and in addition to the Committees on Energy and Commerce, Education and Workforce, the Judiciary, Agriculture, and Ways and Means, for a period to be subsequently determined by the Speaker, in each case for consideration of such provisions as fall within the jurisdiction of the committee concerned.", "date": "2026-04-30T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Submitted in House", "date": "2026-04-30T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "Eleanor Holmes Norton", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Eleanor Holmes Norton\"}", "organization_id": null}, {"name": "Lateefah Simon", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id"