{"legislative_session": "119", "identifier": "HR 8619", "title": "Kimberly Vaughan Firearm Safe Storage Act", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [], "other_titles": [{"note": "", "title": "To make unlawful the sale of any firearm by a licensed manufacturer, licensed importer, or licensed dealer without a written notice promoting safe storage and a safe storage device, to create and disseminate best practices regarding safe firearm storage, to create a grant program for the distribution of safe storage devices, and to amend the Internal Revenue Code of 1986 to allow for a credit against tax for sales at retail of safe firearm storage devices, and for other purposes."}], "other_identifiers": [{"identifier": "ocd-bill-us-119-hr8619"}], "actions": [{"description": "Sponsor introductory remarks on measure. (CR H3541)", "date": "2026-05-15T04:00:00+00:00", "organization_id": "~{\"classification\": \"legislature\"}", "classification": [], "related_entities": []}, {"description": "Referred to the Committee on the Judiciary, and in addition to the Committee on Ways and Means, for a period to be subsequently determined by the Speaker, in each case for consideration of such provisions as fall within the jurisdiction of the committee concerned.", "date": "2026-04-30T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Introduced in House", "date": "2026-04-30T04:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "Madeleine Dean", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Madeleine Dean\"}", "organization_id": null}, {"name": "Sam T. Liccardo", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"nam